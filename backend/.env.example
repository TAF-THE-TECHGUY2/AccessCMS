# Backend local development defaults
NODE_ENV=development
# Change this if port 5000 is already occupied on your machine.
PORT=5000

# Local MongoDB example:
# mongodb://127.0.0.1:27017/access-properties
MONGODB_URI=mongodb://127.0.0.1:27017/access-properties

# Replace these in shared/staging/production environments.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated values are supported when multiple browser origins need access.
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

STORAGE_DRIVER=local
UPLOAD_DIR=uploads
LOG_LEVEL=info

# Only needed when STORAGE_DRIVER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
