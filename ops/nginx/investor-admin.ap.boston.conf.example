server {
    listen 80;
    listen [::]:80;
    server_name investor-admin.ap.boston;

    root /var/www/AccessCMS/system/backend-laravel/public;
    index index.php index.html;

    client_max_body_size 25m;

    access_log /var/log/nginx/investor-admin.ap.boston.access.log;
    error_log /var/log/nginx/investor-admin.ap.boston.error.log;

    location = / {
        return 302 /admin/login;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
